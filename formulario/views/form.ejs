<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Agendamento</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-dark text-white">
<div class="container mt-5">

<div class="text-md-center">
<h2>Agendamento de Consulta</h2>
</div>

<!-- ERROS -->
<% if (erros.length > 0) { %>
<div class="alert alert-danger">
    <ul>
        <% erros.forEach(e => { %>
            <li><%= e %></li>
        <% }) %>
    </ul>
</div>
<% } %>

<form method="POST" action="/agendamento">

<h4>Dados do paciente</h4>
<div class="row">
    <div class="col-md-6 mb-3">
        <input name="nome" class="form-control" placeholder="Nome">
    </div>
    <div class="col-md-6 mb-3">
        <input name="sobrenome" class="form-control" placeholder="Sobrenome">
    </div>

    <div class="col-md-6 mb-3">
        <input name="cpf" class="form-control" placeholder="CPF">
    </div>
    <div class="col-md-6 mb-3">
        <input type="date" name="nascimento" class="form-control">
    </div>

    <div class="col-md-6 mb-3">
        <input name="telefone" class="form-control" placeholder="Telefone">
    </div>
    <div class="col-md-6 mb-3">
        <input name="cep" class="form-control" placeholder="CEP">
    </div>

    <div class="col-12 mb-3">
        <input name="endereco" class="form-control" placeholder="Endereço">
    </div>
</div>

<h4>Dados da consulta</h4>

<div class="row">
    <div class="col-md-6 mb-3">
        <select name="clinica" class="form-control">
            <option value="">Clínica</option>
            <option>Clínica A</option>
            <option>Clínica B</option>
        </select>
    </div>

    <div class="col-md-6 mb-3">
        <select name="especialidade" class="form-control">
            <option value="">Especialidade</option>
            <option>Cardiologia</option>
            <option>Dermatologia</option>
        </select>
    </div>

    <div class="col-md-6 mb-3">
        <input type="datetime-local" name="dataHora" class="form-control">
    </div>

    <div class="col-12 mb-3">
        <textarea name="observacao" class="form-control" placeholder="Observação"></textarea>
    </div>
</div>

<button class="btn btn-light w-100">Enviar</button>

</form>
</div>
</body>
</html>